# API Keys Configuration
# Copy this file to .env and replace with your actual API keys

# Mapbox API Token
# Get your free token from: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# Weatherstack API Key
# Get your free key from: https://weatherstack.com/signup/free
WEATHERSTACK_KEY=your_weatherstack_key_here

# Server Configuration
# Port number for the Express server (default: 3000)
PORT=3000


